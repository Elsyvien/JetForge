{
  "name": "txtjet-syntax",
  "displayName": "TxtJet Syntax",
  "description": "Syntax highlighting and editor support for .txtjet Java emitter templates.",
  "version": "0.0.13",
  "publisher": "elsyvien",
  "author": "Max Staneker",
  "license": "MIT",
  "icon": "assets/icon.png",
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elsyvien/JetForge.git"
  },
  "bugs": {
    "url": "https://github.com/Elsyvien/JetForge/issues"
  },
  "homepage": "https://github.com/Elsyvien/JetForge#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "keywords": [
    "txtjet",
    "jet",
    "template",
    "java",
    "jsp",
    "emitter",
    "syntax",
    "highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "txtjet",
        "aliases": [
          "TxtJet",
          "txtjet"
        ],
        "extensions": [
          ".txtjet",
          ".jet",
          ".javajet",
          ".htmljet",
          ".xmljet",
          ".cjet",
          ".pythonjet"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "txtjet-java",
        "aliases": [
          "TxtJet Java Output",
          "TxtJet Generated Java",
          "txtjet-java"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "txtjet-html",
        "aliases": [
          "TxtJet HTML Output",
          "TxtJet Generated HTML",
          "txtjet-html"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "txtjet-xml",
        "aliases": [
          "TxtJet XML Output",
          "TxtJet Generated XML",
          "txtjet-xml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "txtjet-c",
        "aliases": [
          "TxtJet C Output",
          "TxtJet Generated C",
          "txtjet-c"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "txtjet-python",
        "aliases": [
          "TxtJet Python Output",
          "TxtJet Generated Python",
          "txtjet-python"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "txtjet",
        "scopeName": "text.txtjet",
        "path": "./syntaxes/txtjet.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java"
        }
      },
      {
        "language": "txtjet-java",
        "scopeName": "source.txtjet.java",
        "path": "./syntaxes/txtjet-java.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java"
        }
      },
      {
        "language": "txtjet-html",
        "scopeName": "text.txtjet.html",
        "path": "./syntaxes/txtjet-html.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java",
          "text.html.basic": "html"
        }
      },
      {
        "language": "txtjet-xml",
        "scopeName": "text.txtjet.xml",
        "path": "./syntaxes/txtjet-xml.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java",
          "text.xml": "xml"
        }
      },
      {
        "language": "txtjet-c",
        "scopeName": "source.txtjet.c",
        "path": "./syntaxes/txtjet-c.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java",
          "source.c": "c"
        }
      },
      {
        "language": "txtjet-python",
        "scopeName": "source.txtjet.python",
        "path": "./syntaxes/txtjet-python.tmLanguage.json",
        "embeddedLanguages": {
          "source.java": "java",
          "source.python": "python"
        }
      },
      {
        "scopeName": "text.txtjet.embedded-expression.injection",
        "path": "./syntaxes/txtjet-expression.injection.tmLanguage.json",
        "injectTo": [
          "source.txtjet.java",
          "text.txtjet.html",
          "text.txtjet.xml",
          "source.txtjet.c",
          "source.txtjet.python"
        ],
        "embeddedLanguages": {
          "source.java": "java"
        }
      }
    ],
    "snippets": [
      {
        "language": "txtjet",
        "path": "./snippets/txtjet.code-snippets"
      },
      {
        "language": "txtjet-java",
        "path": "./snippets/txtjet.code-snippets"
      },
      {
        "language": "txtjet-html",
        "path": "./snippets/txtjet.code-snippets"
      },
      {
        "language": "txtjet-xml",
        "path": "./snippets/txtjet.code-snippets"
      },
      {
        "language": "txtjet-c",
        "path": "./snippets/txtjet.code-snippets"
      },
      {
        "language": "txtjet-python",
        "path": "./snippets/txtjet.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "txtjet.detectTargetLanguage",
        "title": "TxtJet: Auto Detect Generated Output Mode"
      },
      {
        "command": "txtjet.selectTargetLanguage",
        "title": "TxtJet: Select Generated Output Mode"
      },
      {
        "command": "txtjet.setLanguage.default",
        "title": "TxtJet: Use Generic Template Mode"
      },
      {
        "command": "txtjet.setLanguage.java",
        "title": "TxtJet: Use Generated Java Output Mode"
      },
      {
        "command": "txtjet.setLanguage.html",
        "title": "TxtJet: Use Generated HTML Output Mode"
      },
      {
        "command": "txtjet.setLanguage.xml",
        "title": "TxtJet: Use Generated XML Output Mode"
      },
      {
        "command": "txtjet.setLanguage.c",
        "title": "TxtJet: Use Generated C Output Mode"
      },
      {
        "command": "txtjet.setLanguage.python",
        "title": "TxtJet: Use Generated Python Output Mode"
      },
      {
        "command": "txtjet.clearLanguage.active",
        "title": "TxtJet: Clear Remembered Target Language"
      },
      {
        "command": "txtjet.clearLanguage.all",
        "title": "TxtJet: Clear All Remembered Target Languages"
      },
      {
        "command": "txtjet.openGeneratedOutputPreview",
        "title": "TxtJet: Open Generated Output Preview"
      },
      {
        "command": "txtjet.openGeneratedJavaPreview",
        "title": "TxtJet: Open Generated Java Template Preview"
      },
      {
        "command": "txtjet.openPreviewBesideSource",
        "title": "TxtJet: Open Preview Beside Source"
      },
      {
        "command": "txtjet.openRegionInGeneratedPreview",
        "title": "TxtJet: Open Region In Generated Preview"
      },
      {
        "command": "txtjet.openRegionInJavaPreview",
        "title": "TxtJet: Open Region In Java Preview"
      },
      {
        "command": "txtjet.revealPreviewFromSource",
        "title": "TxtJet: Reveal Generated Output Preview From Source"
      },
      {
        "command": "txtjet.revealSourceFromPreview",
        "title": "TxtJet: Reveal Source From Preview"
      },
      {
        "command": "txtjet.generateOutput",
        "title": "TxtJet: Generate Output File"
      },
      {
        "command": "txtjet.diffLastGeneratedOutput",
        "title": "TxtJet: Diff Current Output Against Last Generation"
      },
      {
        "command": "txtjet.compileTemplate",
        "title": "TxtJet: Compile Template With External Compiler",
        "category": "TxtJet"
      },
      {
        "command": "txtjet.validateWithCompiler",
        "title": "TxtJet: Validate Template With External Compiler",
        "category": "TxtJet"
      }
    ],
    "configuration": {
      "title": "TxtJet",
      "properties": {
        "txtjet.autoDetect.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically infer and switch the target language for files opened in the default TxtJet mode."
        },
        "txtjet.defaultTargetLanguage": {
          "type": "string",
          "default": "txtjet",
          "enum": [
            "txtjet",
            "txtjet-java",
            "txtjet-html",
            "txtjet-xml",
            "txtjet-c",
            "txtjet-python"
          ],
          "description": "Fallback TxtJet target language used when Auto Detect is disabled."
        },
        "txtjet.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable lightweight TxtJet syntax diagnostics."
        },
        "txtjet.diagnostics.severity": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "description": "Severity used for TxtJet syntax diagnostics."
        },
        "txtjet.diagnostics.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 0,
          "description": "Maximum UTF-8 file size in KB for running TxtJet diagnostics. Set to 0 to disable the size limit."
        },
        "txtjet.diagnostics.generatedJava.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Map diagnostics from open generated Java preview documents back to the source template. Experimental and disabled by default."
        },
        "txtjet.diagnostics.compiler.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable compiler-backed diagnostics produced by TxtJet: Validate Template With External Compiler."
        },
        "txtjet.diagnostics.compiler.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run compiler-backed validation when a TxtJet template is saved."
        },
        "txtjet.diagnostics.compiler.problemMatcher": {
          "type": "string",
          "default": "^(?<file>.*?):(?<line>\\d+):(?<column>\\d+):(?:\\s*(?<severity>error|warning|info|information|hint):)?\\s*(?<message>.+)$",
          "markdownDescription": "Regex used to parse compiler diagnostics from stdout and stderr. The default supports `file:line:column: severity: message` and `file:line:column: message`; custom expressions should expose `file`, `line`, `column`, optional `severity`, and `message` capture groups."
        },
        "txtjet.codeActions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Quick Fix actions for TxtJet diagnostics."
        },
        "txtjet.completions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TxtJet marker and directive completions."
        },
        "txtjet.javaIntelliSense.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Java IntelliSense forwarding for TxtJet scriptlet, expression, and declaration blocks when Java tooling is available."
        },
        "txtjet.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the TxtJet generated output mode selector in the status bar."
        },
        "txtjet.previews.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable read-only TxtJet generated preview documents."
        },
        "txtjet.previews.openBeside": {
          "type": "boolean",
          "default": true,
          "description": "Open TxtJet previews beside the source document by default."
        },
        "txtjet.previews.generatedJava.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable generated Java template preview documents."
        },
        "txtjet.navigation.includeDefinitions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Go to Definition for TxtJet include and skeleton file attributes."
        },
        "txtjet.resolution.includePaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional workspace-relative or absolute directories used to resolve TxtJet include files. Supports ${workspaceFolder}."
        },
        "txtjet.resolution.skeletonPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional workspace-relative or absolute directories used to resolve TxtJet skeleton files. Supports ${workspaceFolder}."
        },
        "txtjet.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable template-aware formatting for TxtJet directives, expressions, scriptlets, and declarations."
        },
        "txtjet.visualDifferentiation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable subtle editor decorations that distinguish TxtJet markers, directives, embedded Java regions, and generated-output regions."
        },
        "txtjet.generation.outputDirectory": {
          "type": "string",
          "default": "${workspaceFolder}/generated",
          "description": "Directory used by TxtJet: Generate Output File. Supports ${workspaceFolder}."
        },
        "txtjet.compiler.command": {
          "type": "string",
          "default": "",
          "markdownDescription": "Shell command used by **TxtJet: Compile Template With External Compiler**. Supports placeholders `${file}`, `${workspaceFolder}`, and `${outputFile}`.",
          "scope": "resource"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "txtjet.selectTargetLanguage",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.detectTargetLanguage",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.default",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.java",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.html",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.xml",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.c",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.setLanguage.python",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.clearLanguage.active",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.openGeneratedOutputPreview",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.openGeneratedJavaPreview",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.openPreviewBesideSource",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.openRegionInGeneratedPreview",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.openRegionInJavaPreview",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.revealPreviewFromSource",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.revealSourceFromPreview",
          "when": "resourceScheme =~ /^txtjet-preview-(output|java)$/"
        },
        {
          "command": "txtjet.generateOutput",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.diffLastGeneratedOutput",
          "when": "resourceExtname =~ /^\\.(txtjet|jet|javajet|htmljet|xmljet|cjet|pythonjet)$/"
        },
        {
          "command": "txtjet.clearLanguage.all"
        },
        {
          "command": "txtjet.compileTemplate",
          "when": "resourceLangId =~ /^txtjet/"
        },
        {
          "command": "txtjet.validateWithCompiler",
          "when": "resourceLangId =~ /^txtjet/"
        }
      ],
      "editor/context": [
        {
          "command": "txtjet.compileTemplate",
          "when": "resourceLangId =~ /^txtjet/",
          "group": "navigation@30"
        },
        {
          "command": "txtjet.validateWithCompiler",
          "when": "resourceLangId =~ /^txtjet/",
          "group": "navigation@31"
        }
      ]
    }
  },
  "activationEvents": [
    "onLanguage:txtjet",
    "onLanguage:txtjet-java",
    "onLanguage:txtjet-html",
    "onLanguage:txtjet-xml",
    "onLanguage:txtjet-c",
    "onLanguage:txtjet-python",
    "onCommand:txtjet.selectTargetLanguage",
    "onCommand:txtjet.detectTargetLanguage",
    "onCommand:txtjet.clearLanguage.active",
    "onCommand:txtjet.clearLanguage.all",
    "onCommand:txtjet.openGeneratedOutputPreview",
    "onCommand:txtjet.openGeneratedJavaPreview",
    "onCommand:txtjet.openPreviewBesideSource",
    "onCommand:txtjet.openRegionInGeneratedPreview",
    "onCommand:txtjet.openRegionInJavaPreview",
    "onCommand:txtjet.revealPreviewFromSource",
    "onCommand:txtjet.revealSourceFromPreview",
    "onCommand:txtjet.generateOutput",
    "onCommand:txtjet.diffLastGeneratedOutput",
    "onCommand:txtjet.compileTemplate",
    "onCommand:txtjet.validateWithCompiler"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node out/detector.test.js && node out/templateModel.test.js && node out/regionClassifier.test.js && node out/javaIntelliSenseBridge.test.js && node out/previewExamples.test.js && node out/scanner.test.js && node out/extensionSupport.test.js && node out/compilerDiagnostics.test.js && node out/formatter.test.js && node out/codeActions.test.js && node out/grammar.test.js && node out/manifest.test.js && node out/packageHygiene.test.js",
    "validate:json": "node -e \"const fs=require('fs'); for (const f of ['package.json','package-lock.json','language-configuration.json','snippets/txtjet.code-snippets', ...fs.readdirSync('syntaxes').map(x=>'syntaxes/'+x)]) JSON.parse(fs.readFileSync(f,'utf8')); console.log('json ok')\"",
    "verify": "npm test && npm run validate:json && npm run package",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "3.6.1",
    "typescript": "^5.4.5"
  }
}
