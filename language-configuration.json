{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "<%",
      "%>"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "{",
      "close": "}"
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*<%\\s*(?:if|for|while|switch|try|else\\b|else\\s+if)\\b.*\\{\\s*%>\\s*$",
    "decreaseIndentPattern": "^\\s*<%\\s*}\\s*(?:else\\s*\\{)?\\s*%>\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^.*<%\\s*(?:if|for|while|switch|try|else\\b|else\\s+if)\\b.*\\{\\s*%>\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*<%\\s*}\\s*%>\\s*$",
      "action": {
        "indent": "outdent"
      }
    }
  ]
}
