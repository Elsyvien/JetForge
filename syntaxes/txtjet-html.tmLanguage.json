{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TxtJet HTML",
  "scopeName": "text.txtjet.html",
  "patterns": [
    {
      "include": "#txtjet-template"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "txtjet-template": {
      "patterns": [
        {
          "include": "#directive"
        },
        {
          "include": "#expression"
        },
        {
          "include": "#declaration"
        },
        {
          "include": "#scriptlet"
        }
      ]
    },
    "directive": {
      "name": "meta.directive.txtjet",
      "begin": "(<%@)\\s*([A-Za-z_][\\w.-]*)?",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.template.begin.txtjet"
        },
        "2": {
          "name": "keyword.control.directive.txtjet"
        }
      },
      "end": "(%>)",
      "endCaptures": {
        "1": {
          "name": "keyword.control.template.end.txtjet"
        }
      },
      "patterns": [
        {
          "include": "#directive-attribute"
        },
        {
          "include": "#directive-string"
        }
      ]
    },
    "expression": {
      "name": "meta.embedded.expression.java.txtjet",
      "begin": "(<%=)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.template.expression.begin.txtjet"
        }
      },
      "end": "(%>)",
      "endCaptures": {
        "1": {
          "name": "keyword.control.template.end.txtjet"
        }
      },
      "contentName": "source.java",
      "patterns": [
        {
          "include": "source.java"
        }
      ]
    },
    "declaration": {
      "name": "meta.embedded.declaration.java.txtjet",
      "begin": "(<%!)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.template.declaration.begin.txtjet"
        }
      },
      "end": "(%>)",
      "endCaptures": {
        "1": {
          "name": "keyword.control.template.end.txtjet"
        }
      },
      "contentName": "source.java",
      "patterns": [
        {
          "include": "source.java"
        }
      ]
    },
    "scriptlet": {
      "name": "meta.embedded.block.java.txtjet",
      "begin": "(<%)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.template.begin.txtjet"
        }
      },
      "end": "(%>)",
      "endCaptures": {
        "1": {
          "name": "keyword.control.template.end.txtjet"
        }
      },
      "contentName": "source.java",
      "patterns": [
        {
          "include": "source.java"
        }
      ]
    },
    "directive-attribute": {
      "name": "entity.other.attribute-name.txtjet",
      "match": "\\b[A-Za-z_][\\w.-]*(?=\\s*=)"
    },
    "directive-string": {
      "name": "string.quoted.double.txtjet",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.txtjet",
          "match": "\\\\."
        }
      ]
    }
  }
}

